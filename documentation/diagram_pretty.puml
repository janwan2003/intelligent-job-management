@startuml diagram
title Platform for Selecting Best Embedding Model - Architecture Overview
top to bottom direction

skinparam shadowing false
skinparam roundCorner 15
skinparam defaultTextAlignment center
skinparam ArrowColor #4B5563
skinparam ArrowThickness 1.2
skinparam ArrowFontSize 11
skinparam backgroundColor #f9f9fbff

' Package styles
skinparam packageStyle rectangle
skinparam RectangleBorderColor #CBD5F5
skinparam RectangleFontSize 12

' Component styles
skinparam componentStyle rectangle

package "User-Facing Layer" #DBEAFE {
    component "Web Frontend\n(Azure App Service)" as Frontend #EFF6FF
    component "Backend API\n(Azure App Service)" as Backend #EFF6FF
    component "User Authentication\n(Azure AD B2C / Entra ID)" as Auth #EFF6FF
}

package "Compute & AI" #DBEAFE {
    component "Azure OpenAI\n(LLM-as-judge,\noptional embeddings)" as OpenAI #EFF6FF
    component "Azure Functions\n(Benchmark Workers)" as Functions #EFF6FF

}

package "Data & Storage" #DBEAFE {
    component "Azure Cosmos DB\n(users, experiments,\nmodel metadata, results)" as Cosmos #EFF6FF
    component "Azure Blob Storage\n(raw uploaded data)" as Blob #EFF6FF
}

' Flows
Frontend -down-> Backend : User requests\n(upload, run benchmark)
Backend -right-> Auth : Login /\nauth checks

Backend -down-> Functions : Trigger benchmark
Functions -right-> OpenAI : LLM-as-judge\nrelevance scoring

Backend -down-> Cosmos : Store/read\nexperiment metadata
Functions -down-> Cosmos : Store\nbenchmark results

Backend -down-> Blob : Upload user data
Functions -down-> Blob : Read\ninput data

@enduml
