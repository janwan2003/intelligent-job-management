{
  "openapi": "3.1.0",
  "info": {
    "title": "Intelligent Job Management Platform",
    "description": "API for Intelligent Job Management",
    "version": "0.1.0"
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "description": "Health check endpoint.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Root  Get"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Detailed health check \u2014 pings DB and checks job runner.",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/nodes": {
      "get": {
        "summary": "List Nodes",
        "description": "List all cluster nodes with their current status.",
        "operationId": "list_nodes_nodes_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/NodeStatus"
                  },
                  "type": "array",
                  "title": "Response List Nodes Nodes Get"
                }
              }
            }
          }
        }
      }
    },
    "/gpu-costs": {
      "get": {
        "summary": "Get Gpu Costs",
        "description": "Return hourly GPU energy costs used by the scheduler for optimization.",
        "operationId": "get_gpu_costs_gpu_costs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "additionalProperties": {
                      "type": "number"
                    },
                    "type": "object"
                  },
                  "type": "object",
                  "title": "Response Get Gpu Costs Gpu Costs Get"
                }
              }
            }
          }
        }
      }
    },
    "/configurations": {
      "get": {
        "summary": "List Configurations",
        "description": "List all valid hardware configurations in the cluster.",
        "operationId": "list_configurations_configurations_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  "type": "array",
                  "title": "Response List Configurations Configurations Get"
                }
              }
            }
          }
        }
      }
    },
    "/jobs": {
      "post": {
        "summary": "Create Job",
        "description": "Create a new job.",
        "operationId": "create_job_jobs_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List Jobs",
        "description": "List all jobs ordered by creation time (newest first).",
        "operationId": "list_jobs_jobs_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "default": 100,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "title": "Offset"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Job"
                  },
                  "title": "Response List Jobs Jobs Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Clear All Jobs",
        "description": "Delete all jobs and their profiling results.",
        "operationId": "clear_all_jobs_jobs_delete",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        }
      }
    },
    "/jobs/{job_id}": {
      "get": {
        "summary": "Get Job",
        "description": "Get a specific job by ID.",
        "operationId": "get_job_jobs__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Job",
        "description": "Delete a job.",
        "operationId": "delete_job_jobs__job_id__delete",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{job_id}/stop": {
      "post": {
        "summary": "Stop Job",
        "description": "Request job to be stopped.",
        "operationId": "stop_job_jobs__job_id__stop_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Stop Job Jobs  Job Id  Stop Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{job_id}/resume": {
      "post": {
        "summary": "Resume Job",
        "description": "Request job to be resumed.",
        "operationId": "resume_job_jobs__job_id__resume_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Resume Job Jobs  Job Id  Resume Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{job_id}/logs": {
      "get": {
        "summary": "Get Job Logs",
        "description": "Return the output log for a job.",
        "operationId": "get_job_logs_jobs__job_id__logs_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/profiling-results/{job_id}": {
      "get": {
        "summary": "Get Profiling Results",
        "description": "Get all profiling results for a job, ordered by duration (fastest first).",
        "operationId": "get_profiling_results_profiling_results__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "title": "Response Get Profiling Results Profiling Results  Job Id  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Job": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "image": {
            "type": "string",
            "title": "Image"
          },
          "command": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Command"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "container_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Container Name"
          },
          "exit_code": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exit Code"
          },
          "progress": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Progress"
          },
          "priority": {
            "type": "integer",
            "title": "Priority",
            "default": 3
          },
          "deadline": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deadline"
          },
          "batch_size": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Batch Size"
          },
          "epochs_total": {
            "type": "integer",
            "title": "Epochs Total",
            "default": 20
          },
          "profiling_epochs_no": {
            "type": "integer",
            "title": "Profiling Epochs No",
            "default": 3
          },
          "assigned_node": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Assigned Node"
          },
          "required_memory_gb": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Required Memory Gb"
          },
          "assigned_gpu_config": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "integer"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Assigned Gpu Config"
          },
          "is_profiling_run": {
            "type": "boolean",
            "title": "Is Profiling Run",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "id",
          "image",
          "command",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "Job",
        "description": "Job response model \u2014 also used to hydrate DB rows via model_validate()."
      },
      "JobCreate": {
        "properties": {
          "image": {
            "type": "string",
            "title": "Image"
          },
          "command": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Command"
          },
          "Priority": {
            "type": "integer",
            "maximum": 5.0,
            "minimum": 1.0,
            "title": "Priority",
            "default": 3
          },
          "deadline": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deadline"
          },
          "batchSize": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Batchsize"
          },
          "profilingEpochsNo": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Profilingepochsno",
            "default": 3
          },
          "epochsTotal": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Epochstotal",
            "default": 20
          },
          "requiredMemoryGb": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Requiredmemorygb"
          }
        },
        "type": "object",
        "required": [
          "image"
        ],
        "title": "JobCreate",
        "description": "Job creation request."
      },
      "NodeResources": {
        "properties": {
          "gpu_type": {
            "type": "string",
            "title": "Gpu Type"
          },
          "gpu_count": {
            "type": "integer",
            "title": "Gpu Count"
          },
          "memory_per_gpu_gb": {
            "type": "integer",
            "title": "Memory Per Gpu Gb"
          }
        },
        "type": "object",
        "required": [
          "gpu_type",
          "gpu_count",
          "memory_per_gpu_gb"
        ],
        "title": "NodeResources",
        "description": "Hardware resources attached to a node (from config JSON)."
      },
      "NodeStatus": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "is_for_profiling": {
            "type": "boolean",
            "title": "Is For Profiling"
          },
          "cost": {
            "type": "number",
            "title": "Cost"
          },
          "resources": {
            "items": {
              "$ref": "#/components/schemas/NodeResources"
            },
            "type": "array",
            "title": "Resources"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": "idle"
          },
          "current_job_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Current Job Ids"
          }
        },
        "type": "object",
        "required": [
          "id",
          "is_for_profiling",
          "cost"
        ],
        "title": "NodeStatus",
        "description": "Node status returned by GET /nodes."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}